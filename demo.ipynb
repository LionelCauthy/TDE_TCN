    "axes[1, 1].set_xlabel('时间 (样本)')\n",
    "axes[1, 1].set_ylabel('幅值')\n",
    "axes[1, 1].set_title('典型样本信号波形对比')\n",
    "axes[1, 1].legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
