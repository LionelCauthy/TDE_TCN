    "                val_outputs = model(val_inputs)\n",
    "\n",
    "                print(\"验证批次时延预测结果:\")\n",
    "                predicted_peaks = extract_peaks_from_heatmap(val_outputs, max_delay, threshold=0.4)\n",
    "                true_peaks = extract_peaks_from_heatmap(val_targets, max_delay, threshold=0.4)\n",
    "\n",
    "                for b in range(4):\n",
