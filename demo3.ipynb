    "                    print(f\"    预测时延 : {['{:.2f}'.format(p) for p in predicted_peaks[b]]}\")\n",
    "\n",
    "                # ==========================================\n",
    "                # --- 新增：一维热力图输出可视化 ---\n",
    "                # ==========================================\n",
