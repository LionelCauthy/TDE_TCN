    "\n",
    "    model = DC_SWCNet(max_delay=max_delay).to(device)\n",
    "    optimizer = torch.optim.Adam(model.parameters(), lr=8e-4, weight_decay=1e-5)\n",
    "\n",
    "    # 采用高斯平滑后的 MSE Loss\n",
    "    criterion = WeightedGaussianMSELoss()\n",
    "\n",
